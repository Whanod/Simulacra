# Base URL for the defi_sim_api backend. The Next.js studio reads this in
# src/lib/config.ts and uses it for every request.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional public Solana RPC endpoint used by the browser-side wallet provider.
# Leave unset to use the public devnet endpoint for read-only wallet development.
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
